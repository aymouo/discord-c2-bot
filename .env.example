# ═══════════════════════════════════════════════════════════════
# SHINSENKYO C2 — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# STATUS LEGEND: [REQUIRED] [OPTIONAL] [AI-ONLY]
# ═══════════════════════════════════════════════════════════════

# ── DISCORD CREDENTIALS [REQUIRED] ─────────────────────────────
DISCORD_TOKEN=your_bot_token_here
ALLOWED_CHANNEL_ID=your_channel_id_here

# ── ALERTS [OPTIONAL] ──────────────────────────────────────────
# Falls back to ALLOWED_CHANNEL_ID if not set
# ALERTS_CHANNEL_ID=your_alerts_channel_id_here

# ── HTTP / STREAMING [REQUIRED for voice/stream features] ──────
# Public URL where the bot's Express server is reachable
# BOT_HTTP_URL=https://your-bot-server.com:3000
PORT=8000

# ── AI CO-PILOT [OPTIONAL — bot works without it] ──────────────
# Google Gemini (FREE — no credit card, 60 req/min)
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_free_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Ollama (free, local)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b

# Claude (paid)
# AI_PROVIDER=claude
# CLAUDE_API_KEY=sk-ant-your_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
