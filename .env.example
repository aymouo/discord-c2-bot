# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Channel where bot responds to commands (required)
ALLOWED_CHANNEL_ID=your_channel_id_here

# Channel where online/offline alerts are sent (optional, defaults to ALLOWED_CHANNEL_ID)
ALERTS_CHANNEL_ID=your_alerts_channel_id_here

# Bot HTTP server URL for live streaming (required for voice stream feature)
# This is the public URL where your bot server is reachable
BOT_HTTP_URL=https://your-bot-server.com:3000

# Port for the internal Express server (default: 8000)
PORT=8000

# ── AI Co-Pilot Configuration ──

# Google Gemini (FREE — no credit card, 60 req/min, all you need)
# Get a free API key at https://aistudio.google.com/apikey (30 seconds, no CC)
GEMINI_API_KEY=your_free_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Advanced: force a different provider
# AI_PROVIDER=ollama  # free local
# AI_PROVIDER=claude  # paid

# Ollama (free, local) — install on your bot server
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b

# Claude (paid) — only if you have Anthropic credits
# CLAUDE_API_KEY=sk-ant-your_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
